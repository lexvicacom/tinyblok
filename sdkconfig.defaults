# Pinned across checkouts. Per-device values (Wi-Fi creds, anything secret)
# stay out of here — set via `idf.py menuconfig`, which writes to the
# gitignored `sdkconfig` file.
CONFIG_IDF_TARGET="esp32c6"

CONFIG_ESPTOOLPY_FLASHMODE_DIO=y
CONFIG_ESPTOOLPY_FLASHFREQ_80M=y
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y

CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

CONFIG_TINYBLOK_NATS_TLS=y
CONFIG_TINYBLOK_NATS_TLS_BUNDLE=y
CONFIG_TINYBLOK_NATS_CREDS_SUPPORT=y

# TweetNaCl signing (creds auth) plus the TLS handshake share the main task
# stack. Default 3584 bytes overflows during crypto_sign — bump to 8 KB.
CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192

# Pump and clock patchbay evaluation runs on Tinyblok's own task, not the
# ESP default event-loop task. Match the main task stack budget.
CONFIG_TINYBLOK_DRIVER_TASK_STACK_SIZE=8192
CONFIG_TINYBLOK_DRIVER_EVENT_QUEUE_LEN=32
