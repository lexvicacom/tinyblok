;; tinyblok.* — C6 board test

;; Each (pump ...) registers a compiled C/Zig symbol as a timed source. Each
;; (fn ...) registers a compiled C/Zig symbol callable from rules or (on-req).
;; Each (on-req ...) registers a NATS request subject and runs patchbay code.
;;
;; Put user-owned implementations in main/c/user.c or main/zig/user.zig, then
;; name the exported symbol in :from.

(pump "tinyblok.heap"   :from tinyblok_free_heap    :type u32      :hz 10)
(pump "tinyblok.rssi"   :from tinyblok_wifi_rssi    :type i32      :hz 10)
(pump "tinyblok.uptime" :from tinyblok_uptime_us    :type uptime-s :hz 10)
(pump "tinyblok.temp"   :from tinyblok_read_temp_c  :type f32      :hz 1)

(fn hello-c   :from tinyblok_hello_c   :input bytes :type bytes)
(fn hello-zig :from tinyblok_hello_zig :input bytes :type bytes)

;; --- heap: dedupe + 1 s rolling avg, alert on low ---
;; :reentrant lets the deduped value re-enter rule eval so the alert below
;; fires off the *stable* signal, not raw heap. Downstream rule sees fewer
;; updates (only when deadband actually moves) and avoids alerting on jitter.
(on "tinyblok.heap" :reentrant true
  (-> payload-float
      (deadband 1024)                                 ; ignore <1 KiB jitter
      (publish! (subject-append "stable"))))

(on "tinyblok.heap"
  (-> payload-float
      (moving-avg 10)
      (round 0)
      (publish! (subject-append "avg1s"))))

(on "tinyblok.heap.stable"
  (when (< payload-float 20480)                       ; <20 KiB free
    (-> payload (rising-edge) (publish! "tinyblok.alert.heap.low"))))

;; --- rssi: drop "not associated" zeros, dedupe, alert on weak link ---
(on "tinyblok.rssi"
  (when (not (= payload-float 0))                     ; 0 = no info
    (-> payload-float
        (deadband 2)                                  ; +/-2 dBm jitter floor
        (publish! (subject-append "stable")))))       ; -> tinyblok.rssi.stable

(on "tinyblok.rssi"
  (when (not (= payload-float 0))
    (-> payload-float (moving-avg :ms 5000)
        (round 0)
        (publish! (subject-append "avg5s")))))

;; Clock-native emitters: sample keeps a fixed cadence after first input;
;; debounce publishes the latest value only after the feed has been quiet.
(on "tinyblok.rssi"
  (when (not (= payload-float 0))
    (-> payload-float
        (sample! :ms 5000 (subject-append "sample5s")))))

(on "tinyblok.rssi"
  (when (not (= payload-float 0))
    (-> payload-float
        (debounce! :ms 1000 (subject-append "settled")))))

(on "tinyblok.rssi"
  (when (and (not (= payload-float 0)) (< payload-float -75))
    (-> payload (rising-edge) (publish! "tinyblok.alert.rssi.weak"))))

;; Throttle uptime to once per minute for dashboards (10 Hz is silly here).
(on "tinyblok.uptime"
  (-> payload-float
      (throttle :ms 60000)
      (round 0)
      (publish! (subject-append "1m"))))

;; --- temp: 1 Hz already, just window it and alert on hot ---
(on "tinyblok.temp"
  (-> payload-float
      (moving-avg 30) ; 30s
      (round 1)
      (publish! (subject-append "avg30s"))))


(on "tinyblok.temp"
  (when (> payload-float 30)
    (-> payload (rising-edge) (publish! "tinyblok.alert.temp.hot"))))

(on "alex"
  (when (= payload 42)
    (-> 1 (publish! "alex.alert"))))

;; Verbatim re-publish: bare `publish!` (no `->`) forwards the original
;; payload bytes unchanged, so ints stay as ints rather than being reformatted
;; through %.6f. Useful for mirroring a feed to a debug subject.
(on "tinyblok.temp"
  (publish! "tinyblok.temp.raw"))

;; 10-sample tick OHLC over the temp feed; emits to
;; tinyblok.temp.bar.{open,high,low,close} every 10 samples (= 10 s @ 1 Hz).
(on "tinyblok.temp"
  (-> payload-float (bar! 10)))

;; 60-second wall-clock OHLC over heap; the bar walker closes idle windows.
(on "tinyblok.heap"
  (-> payload-float (bar! :ms 60000)))

;; Rolling stats over the last 30 temp samples.
(on "tinyblok.temp"
  (-> payload-float (moving-max 30) (round 1)
      (publish! (subject-append "max30s"))))

(on "tinyblok.temp"
  (-> payload-float (moving-min 30) (round 1)
      (publish! (subject-append "min30s"))))

;; Quantize heap to 4 KiB buckets, clamp absurd RSSI readings to a
;; sensible range, and count temp samples seen.
(on "tinyblok.heap"
  (-> payload-float (quantize 4096)
      (publish! (subject-append "bucket"))))

(on "tinyblok.rssi"
  (when (not (= payload-float 0))
    (-> payload-float (clamp -100 0)
        (publish! (subject-append "clamped")))))

(on "tinyblok.temp"
  (count!))

;; Request/reply endpoints. Tinyblok only answers fixed request subjects;
;; the requester owns the _INBOX reply subject.
(on-req "tinyblok.req.ping"
  (reply! "pong"))

(on-req "tinyblok.req.uptime"
  (-> uptime-s ; the fn to call, c or zig
      (reply!)))

(on-req "tinyblok.req.hello-c"
  (reply! (hello-c payload)))

(on-req "tinyblok.req.hello-zig"
  (reply! (hello-zig payload)))
